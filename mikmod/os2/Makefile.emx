# GNU Makefile for OS/2 -- using GCC/EMX KLIBC environment
#

# The tools
ifeq ($(CROSS),)
CC=gcc
else
CC=$(CROSS)-gcc
endif

CFLAGS = -O2 -Wall -Zmt
CPPFLAGS = -DHAVE_CONFIG_H
INCLUDE = -I. -I../src
LDFLAGS = -Zomf -Zmt -L. -lmikmod
# if linking against static libmikmod.a, mmpm2 is needed too (for drv_os2 and drv_dart.)
LDFLAGS+= -lmmpm2

OBJS= display.o marchive.o mconfedit.o mconfig.o mdialog.o mikmod.o mlist.o mlistedit.o \
	mmenu.o mplayer.o mutilities.o mwidget.o mwindow.o rcfile.o getopt_long.o

# Build rules
%.o: ../src/%.c
	$(CC) $(CFLAGS) $(CPPFLAGS) $(INCLUDE) -o $@ -c $<

all: mikmod.exe

clean:
	$(RM) *.o mikmod.exe

mikmod.exe: $(OBJS)
	$(CC) -o $@ $^ $(LDFLAGS)

display.o: config.h ../src/display.h ../src/player.h ../src/mconfig.h \
  ../src/rcfile.h ../src/mlist.h ../src/mutilities.h ../src/mwindow.h \
  ../src/mconfedit.h ../src/mmenu.h ../src/keys.h ../src/mplayer.h \
  ../src/mlistedit.h
marchive.o: config.h ../src/mlist.h ../src/marchive.h ../src/mconfig.h \
  ../src/rcfile.h ../src/mutilities.h ../src/display.h
mconfedit.o: config.h ../src/rcfile.h ../src/mconfig.h \
  ../src/mconfedit.h ../src/mmenu.h ../src/mwindow.h ../src/mlist.h \
  ../src/mdialog.h ../src/mwidget.h ../src/mutilities.h
mconfig.o: config.h ../src/player.h ../src/mconfig.h ../src/rcfile.h \
  ../src/mwindow.h ../src/mlist.h ../src/mutilities.h
mdialog.o: config.h ../src/mwidget.h ../src/mwindow.h ../src/mconfig.h \
  ../src/rcfile.h ../src/mdialog.h ../src/display.h ../src/mutilities.h
mikmod.o: config.h ../src/getopt_long.h ../src/player.h ../src/mutilities.h \
  ../src/display.h ../src/rcfile.h ../src/mconfig.h ../src/mlist.h \
  ../src/mlistedit.h ../src/mmenu.h ../src/mwindow.h ../src/marchive.h \
  ../src/mdialog.h ../src/mwidget.h ../src/mplayer.h ../src/keys.h
mlist.o: config.h ../src/mlist.h ../src/marchive.h ../src/mutilities.h
mlistedit.o: config.h ../src/mlistedit.h ../src/mmenu.h \
  ../src/mwindow.h ../src/mconfig.h ../src/rcfile.h ../src/mlist.h \
  ../src/player.h ../src/mdialog.h ../src/mwidget.h ../src/mconfedit.h \
  ../src/marchive.h ../src/keys.h ../src/display.h ../src/mutilities.h
mmenu.o: config.h ../src/display.h ../src/mmenu.h ../src/mwindow.h \
  ../src/mconfig.h ../src/rcfile.h ../src/mdialog.h ../src/mwidget.h \
  ../src/keys.h ../src/mutilities.h
mplayer.o: config.h ../src/mplayer.h ../src/mthreads.h ../src/mconfig.h \
  ../src/rcfile.h ../src/mutilities.h
mutilities.o: config.h ../src/player.h ../src/mlist.h ../src/marchive.h \
  ../src/mutilities.h
mwidget.o: config.h ../src/display.h ../src/player.h ../src/mwindow.h \
  ../src/mconfig.h ../src/rcfile.h ../src/mwidget.h ../src/keys.h \
  ../src/mutilities.h
mwindow.o: config.h ../src/display.h ../src/player.h ../src/mwindow.h \
  ../src/mconfig.h ../src/rcfile.h ../src/mutilities.h ../src/keys.h \
  ../src/mthreads.h ../src/os2video.inc
rcfile.o: config.h ../src/rcfile.h ../src/mutilities.h

getopt_long.o: ../src/getopt_long.h
